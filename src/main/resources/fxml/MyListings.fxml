<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.matraknhash.ui.controller.MyListingsController"
      spacing="18">
    <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>

    <VBox styleClass="card" minWidth="320" prefWidth="340" spacing="10">
        <Label text="Add New Listing" styleClass="section-title"/>
        <Label text="SKU (unique)"/>      <TextField fx:id="skuField"/>
        <Label text="Name"/>              <TextField fx:id="nameField"/>
        <Label text="Category"/>          <TextField fx:id="categoryField"/>
        <HBox spacing="8">
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Car make"/><TextField fx:id="makeField"/>
            </VBox>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Car model"/><TextField fx:id="modelField"/>
            </VBox>
        </HBox>
        <HBox spacing="8">
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Sell price (EGP)"/><TextField fx:id="priceField"/>
            </VBox>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Initial stock"/><TextField fx:id="qtyField"/>
            </VBox>
        </HBox>
        <Label text="Source supplier (★ trusted skips review)"/>
        <ComboBox fx:id="supplierCombo" prefWidth="320"/>

        <Label fx:id="formError" styleClass="error-label" managed="false" visible="false" wrapText="true"/>
        <Label fx:id="formInfo"  styleClass="muted"       managed="false" visible="false" wrapText="true"/>

        <HBox spacing="8">
            <padding><Insets top="6"/></padding>
            <Button text="Clear"  styleClass="btn-secondary" onAction="#onClear"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Submit for review" styleClass="btn-primary" onAction="#onSubmit"/>
        </HBox>
    </VBox>

    <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="My Listings" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#onRefresh" styleClass="btn-secondary"/>
        </HBox>
        <TableView fx:id="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"    text="ID"       prefWidth="50"/>
                <TableColumn fx:id="colSku"   text="SKU"      prefWidth="100"/>
                <TableColumn fx:id="colName"  text="Name"     prefWidth="200"/>
                <TableColumn fx:id="colPrice" text="Price"    prefWidth="90"/>
                <TableColumn fx:id="colQty"   text="Stock"    prefWidth="60"/>
                <TableColumn fx:id="colStat"  text="Status"   prefWidth="140"/>
                <TableColumn fx:id="colNote"  text="Note"     prefWidth="200"/>
            </columns>
        </TableView>
    </VBox>
</HBox>
