<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.matraknhash.ui.controller.CartController"
      spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="20" bottom="18" left="20"/></padding>

    <Label text="Your Cart" styleClass="page-h1"/>
    <Label fx:id="sellerLine" text="" styleClass="muted"/>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colPart"  text="Part"      prefWidth="220"/>
            <TableColumn fx:id="colQty"   text="Qty"       prefWidth="60"/>
            <TableColumn fx:id="colPrice" text="Unit"      prefWidth="80"/>
            <TableColumn fx:id="colSub"   text="Subtotal"  prefWidth="100"/>
            <TableColumn fx:id="colDel"   text=""          prefWidth="60"/>
        </columns>
    </TableView>
 
    <VBox spacing="4">
        <Label text="Shipping Address" styleClass="muted" style="-fx-font-weight: bold;"/>
        <TextField fx:id="addressField" promptText="Enter your shipping address (e.g. 12 El Nasr St, Maadi, Cairo)..."/>
    </VBox>
 
    <HBox alignment="CENTER_RIGHT" spacing="14">
        <Label text="Subtotal:" styleClass="muted"/>
        <Label fx:id="lblTotal" text="0 EGP" styleClass="page-h2"/>
    </HBox>

    <Label fx:id="status" wrapText="true" styleClass="muted"/>

    <HBox spacing="10">
        <Button text="Keep shopping" onAction="#onClose" styleClass="btn-secondary"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnEmpty"    text="Empty cart"  onAction="#onEmpty"    styleClass="btn-danger"/>
        <Button fx:id="btnCheckout" text="Place Order" onAction="#onCheckout" styleClass="btn-primary"/>
    </HBox>
</VBox>
