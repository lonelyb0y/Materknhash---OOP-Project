<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.matraknhash.ui.controller.MyServiceOffersController"
      spacing="14" styleClass="page-root">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <Label text="My Service Offers" styleClass="page-h1"/>
    <Label text="Publish services your workshop offers. New offers go to the admin for review before they appear on the customer marketplace."
           styleClass="muted" wrapText="true"/>

    <TitledPane text="Add a new offer" expanded="true">
        <GridPane hgap="12" vgap="8">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <columnConstraints>
                <ColumnConstraints minWidth="100"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <Label text="Title"        GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="title"    promptText="Front brake pad replacement" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Price (EGP)"  GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="price"    promptText="800" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Description"  GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextArea  fx:id="desc"     prefRowCount="3" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <HBox spacing="10" alignment="CENTER_RIGHT" GridPane.rowIndex="3" GridPane.columnIndex="1">
                <Button text="Submit for review" onAction="#onSubmit" styleClass="btn-primary"/>
            </HBox>
        </GridPane>
    </TitledPane>

    <Label fx:id="status" wrapText="true" styleClass="muted"/>

    <Label text="Your offers" styleClass="section-title"/>
    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"     text="#"        prefWidth="60"/>
            <TableColumn fx:id="colTitle"  text="Title"    prefWidth="220"/>
            <TableColumn fx:id="colPrice"  text="Price"    prefWidth="100"/>
            <TableColumn fx:id="colStatus" text="Status"   prefWidth="160"/>
            <TableColumn fx:id="colReason" text="Reason"   prefWidth="240"/>
        </columns>
    </TableView>
</VBox>
