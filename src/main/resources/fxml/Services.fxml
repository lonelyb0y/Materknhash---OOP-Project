<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.matraknhash.ui.controller.ServicesController"
      spacing="14" styleClass="page-root">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Service Centers" styleClass="page-h1"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblCount" text="0 services" styleClass="muted"/>
        <Button text="Refresh" onAction="#onRefresh" styleClass="btn-secondary"/>
    </HBox>

    <Label text="Browse approved auto-repair services and book one. The workshop will see your request and accept or decline."
           styleClass="muted" wrapText="true"/>

    <SplitPane dividerPositions="0.55" VBox.vgrow="ALWAYS">
        <items>
            <VBox spacing="6">
                <Label text="Available services" styleClass="section-title"/>
                <TableView fx:id="offerTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTitle"  text="Service" prefWidth="220"/>
                        <TableColumn fx:id="colCenter" text="Center"  prefWidth="160"/>
                        <TableColumn fx:id="colPrice"  text="Price"   prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10">
                <Label fx:id="lblHeader" text="Pick a service →" styleClass="section-title"/>
                <Label fx:id="lblDesc" wrapText="true" styleClass="muted"/>
                <Label text="Vehicle / notes" styleClass="form-label"/>
                <TextArea fx:id="vehicleNote" promptText="e.g. 2018 Hyundai Elantra, 60,000 km" prefRowCount="3"/>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button fx:id="btnBook" text="Book service" onAction="#onBook" styleClass="btn-primary" disable="true"/>
                </HBox>
                <Label fx:id="status" wrapText="true" styleClass="muted"/>
            </VBox>
        </items>
    </SplitPane>
</VBox>
