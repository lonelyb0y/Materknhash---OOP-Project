<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.matraknhash.ui.controller.SettingsController"
      spacing="14">

    <VBox styleClass="card" spacing="8">
        <Label text="System Information" styleClass="section-title"/>
        <HBox spacing="10"><Label text="Database file:" styleClass="muted"/><Label fx:id="lblDb"/></HBox>
        <HBox spacing="10"><Label text="Socket server:" styleClass="muted"/><Label fx:id="lblSocket"/></HBox>
        <HBox spacing="10"><Label text="Stock monitor:" styleClass="muted"/><Label fx:id="lblMonitor"/></HBox>
    </VBox>

    <VBox styleClass="card" spacing="8">
        <Label text="About" styleClass="section-title"/>
        <Label text="Metrkansh ERP v1.0.0"/>
        <Label text="Advanced Programming Applications - Week 12 Project" styleClass="muted"/>
        <Label text="Java 17 + JavaFX 21 + SQLite + FXGL" styleClass="muted"/>
    </VBox>
</VBox>
