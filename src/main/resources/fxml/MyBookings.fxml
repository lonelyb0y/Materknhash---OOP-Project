<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.matraknhash.ui.controller.MyBookingsController"
      spacing="14" styleClass="page-root">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="My Service Bookings" styleClass="page-h1"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#onRefresh" styleClass="btn-secondary"/>
    </HBox>
    <Label text="Workshops accept your booking, then mark it complete when the work is done."
           styleClass="muted" wrapText="true"/>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"     text="#"        prefWidth="60"/>
            <TableColumn fx:id="colTitle"  text="Service"  prefWidth="200"/>
            <TableColumn fx:id="colCenter" text="Center"   prefWidth="160"/>
            <TableColumn fx:id="colPrice"  text="Price"    prefWidth="100"/>
            <TableColumn fx:id="colStatus" text="Status"   prefWidth="120"/>
            <TableColumn fx:id="colWhen"   text="Booked"   prefWidth="140"/>
        </columns>
    </TableView>
</VBox>
