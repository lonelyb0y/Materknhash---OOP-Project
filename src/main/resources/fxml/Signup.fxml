<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.matraknhash.ui.controller.SignupController"
           styleClass="login-backdrop"
           prefWidth="1024" prefHeight="640">

    <VBox alignment="CENTER" styleClass="login-card" maxWidth="460">
        <VBox alignment="CENTER" spacing="2">
            <Label text="Metrkansh" styleClass="brand-title"/>
            <Label text="Auto Parts ERP" styleClass="brand-subtitle"/>
        </VBox>

        <Region prefHeight="6"/>

        <Label text="Create your account" styleClass="welcome"/>
        <Label fx:id="subtitleLabel" text="Pick a role to get started"
               styleClass="welcome-sub" wrapText="true"/>

        <Region prefHeight="6"/>

        <Label text="I want to..." styleClass="muted"/>
        <ComboBox fx:id="roleCombo" prefWidth="380"/>

        <TextField     fx:id="fullNameField" promptText="Full name"/>
        <TextField     fx:id="usernameField" promptText="Username"/>
        <PasswordField fx:id="passwordField" promptText="Password (4+ chars)"/>

        <Label fx:id="errorLabel" styleClass="error-label" managed="false" visible="false"/>
        <Label fx:id="okLabel"    styleClass="muted"       managed="false" visible="false" wrapText="true"/>

        <Button text="Sign up" onAction="#onSignup" styleClass="btn-primary"
                prefWidth="380" defaultButton="true"/>

        <HBox alignment="CENTER" spacing="6">
            <padding><Insets top="6"/></padding>
            <Label text="Already have an account?" styleClass="muted"/>
            <Hyperlink text="Login" onAction="#onBackToLogin"/>
        </HBox>
    </VBox>

</StackPane>
