<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.matraknhash.ui.controller.SellerOrdersController"
      spacing="14" styleClass="page-root">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Incoming Orders" styleClass="page-h1"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblCount" text="0 awaiting you" styleClass="muted"/>
        <Button text="Refresh" onAction="#onRefresh" styleClass="btn-secondary"/>
    </HBox>

    <SplitPane dividerPositions="0.45" VBox.vgrow="ALWAYS">
        <items>
            <VBox spacing="8">
                <Label text="Orders for your listings" styleClass="section-title"/>
                <TableView fx:id="orderTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId"    text="Order"   prefWidth="80"/>
                        <TableColumn fx:id="colBuyer" text="Buyer"   prefWidth="140"/>
                        <TableColumn fx:id="colTotal" text="Total"   prefWidth="100"/>
                        <TableColumn fx:id="colStat"  text="Status"  prefWidth="140"/>
                        <TableColumn fx:id="colWhen"  text="Placed"  prefWidth="140"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10">
                <Label fx:id="lblHeader" text="Pick an order →" styleClass="section-title"/>
                <TableView fx:id="lineTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colLname" text="Part"     prefWidth="220"/>
                        <TableColumn fx:id="colLqty"  text="Qty"      prefWidth="60"/>
                        <TableColumn fx:id="colLprc"  text="Unit"     prefWidth="90"/>
                        <TableColumn fx:id="colLsub"  text="Subtotal" prefWidth="100"/>
                    </columns>
                </TableView>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button fx:id="btnPrint" text="🖨  Print receipt &amp; Fulfill"
                            onAction="#onPrint" styleClass="btn-primary" disable="true"/>
                    <Button fx:id="btnAcceptReturn" text="✅  Accept Return"
                            onAction="#onAcceptReturn" styleClass="btn-danger" disable="true"/>
                </HBox>
                <Label fx:id="status" wrapText="true" styleClass="muted"/>
            </VBox>
        </items>
    </SplitPane>
</VBox>
