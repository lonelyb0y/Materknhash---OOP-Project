<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.matraknhash.ui.controller.ListingReviewController"
      spacing="14" styleClass="page-root">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="title" text="Listings Review" styleClass="page-h1"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblCount" text="0 awaiting" styleClass="muted"/>
        <Button text="Refresh" onAction="#onRefresh" styleClass="btn-secondary"/>
    </HBox>

    <Label fx:id="subtitle" text="" styleClass="muted" wrapText="true"/>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"     text="ID"        prefWidth="50"/>
            <TableColumn fx:id="colSku"    text="SKU"       prefWidth="100"/>
            <TableColumn fx:id="colName"   text="Name"      prefWidth="220"/>
            <TableColumn fx:id="colSeller" text="Seller"    prefWidth="140"/>
            <TableColumn fx:id="colPrice"  text="Price"     prefWidth="90"/>
            <TableColumn fx:id="colQty"    text="Stock"     prefWidth="60"/>
            <TableColumn fx:id="colSup"    text="Supplier"  prefWidth="160"/>
            <TableColumn fx:id="colAct"    text="Decision"  prefWidth="200"/>
        </columns>
    </TableView>

    <Label fx:id="status" wrapText="true" styleClass="muted"/>
</VBox>
