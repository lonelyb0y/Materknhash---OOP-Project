<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.matraknhash.ui.controller.CenterBookingsController"
      spacing="14" styleClass="page-root">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Incoming Service Bookings" styleClass="page-h1"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#onRefresh" styleClass="btn-secondary"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"        text="#"        prefWidth="60"/>
            <TableColumn fx:id="colService"   text="Service"  prefWidth="200"/>
            <TableColumn fx:id="colCustomer"  text="Customer" prefWidth="160"/>
            <TableColumn fx:id="colVehicle"   text="Vehicle"  prefWidth="220"/>
            <TableColumn fx:id="colStatus"    text="Status"   prefWidth="140"/>
            <TableColumn fx:id="colWhen"      text="Booked"   prefWidth="140"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnAccept"   text="Accept"          onAction="#onAccept"   styleClass="btn-primary"   disable="true"/>
        <Button fx:id="btnReject"   text="Decline"         onAction="#onReject"   styleClass="btn-danger"    disable="true"/>
        <Button fx:id="btnComplete" text="Mark complete"   onAction="#onComplete" styleClass="btn-secondary" disable="true"/>
    </HBox>
    <Label fx:id="status" wrapText="true" styleClass="muted"/>
</VBox>
