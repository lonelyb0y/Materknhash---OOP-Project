<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.matraknhash.ui.controller.LoginController"
           styleClass="login-backdrop"
           prefWidth="1024" prefHeight="640">

    <VBox alignment="CENTER" styleClass="login-card" maxWidth="420">
        <VBox alignment="CENTER" spacing="2">
            <Label text="Metrkansh" styleClass="brand-title"/>
            <Label text="Auto Parts ERP" styleClass="brand-subtitle"/>
        </VBox>

        <Region prefHeight="6"/>

        <Label text="Welcome Back!" styleClass="welcome"/>
        <Label text="Please login to your account" styleClass="welcome-sub"/>

        <Region prefHeight="6"/>

        <TextField fx:id="usernameField" promptText="Username"/>
        <PasswordField fx:id="passwordField" promptText="Password"/>

        <Label fx:id="errorLabel" styleClass="error-label" managed="false" visible="false"/>

        <Button text="Login" onAction="#onLogin" styleClass="btn-primary" prefWidth="340" defaultButton="true"/>

        <HBox alignment="CENTER">
            <padding><Insets top="8"/></padding>
            <Label text="© 2026 Metrkansh ERP System" styleClass="muted"/>
        </HBox>
    </VBox>

</StackPane>
